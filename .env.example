OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_S=30

DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_TIMEOUT_S=30

# Option A: provide full URL directly
# DATABASE_URL=postgresql+psycopg2://postgres:root@localhost:5432/ai_visibility_db

# Option B: provide POSTGRES_* and app builds DATABASE_URL automatically
POSTGRES_DB=ai_visibility_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

LOG_LEVEL=INFO
